ARG FRONTEND_NODE_IMAGE=node:24-alpine
FROM ${FRONTEND_NODE_IMAGE} AS frontend-builder

WORKDIR /src/frontend

COPY frontend/package*.json ./
RUN npm ci

COPY frontend ./
RUN npm run build

FROM mcp/playwright:latest

USER root

RUN sed -i 's|deb.debian.org|mirrors.tuna.tsinghua.edu.cn|g' /etc/apt/sources.list.d/debian.sources 2>/dev/null || true
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv fonts-noto-cjk ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV MEDIA_DIRS=/media
ENV TRASH_DIR=/trash
ENV APP_DATA_DIR=/data
ENV JAVDB_CHROMIUM_PATH=/ms-playwright/chromium-1224/chrome-linux64/chrome

COPY deploy/unraid-frontend/requirements.txt ./requirements.txt
RUN python3 -m pip install --break-system-packages --no-cache-dir -r requirements.txt

COPY app ./app
COPY --from=frontend-builder /src/frontend/dist ./frontend/dist

EXPOSE 18180

ENTRYPOINT []
CMD ["python3", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "18180"]
